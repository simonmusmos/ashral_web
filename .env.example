PORT=3000

# Minimum CLI version required to create a session (e.g. "0.1.0")
# If unset, no version check is performed.
MIN_CLI_VERSION=0.1.0

# OpenAI API key for extracting clean notification bodies from raw terminal output.
# If unset, rawText is ignored and the original body is used as-is.
OPENAI_API_KEY=sk-...

# Option A: path to a service account JSON file
FIREBASE_SERVICE_ACCOUNT=/path/to/service-account.json

# Option B: the service account JSON as an inline string (useful for Railway/Render secrets)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
